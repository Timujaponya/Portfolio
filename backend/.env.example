# MongoDB Connection
MONGODB_URI=mongodb+srv://your-username:your-password@cluster.mongodb.net/your-database?retryWrites=true&w=majority

# GitHub API Token (optional - for fetching GitHub repos)
GITHUB_TOKEN=your_github_personal_access_token

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Origins (comma separated)
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174,https://your-client-service.up.railway.app

# Upload storage
# Railway volume mount or local folder path
UPLOAD_DIR=./uploads

# Optional absolute base URL used for upload links
# Example: https://your-backend-service.up.railway.app
PUBLIC_BASE_URL=

# Resend Email (Contact Form)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
# Resend verified sender (or onboarding@resend.dev for test)
CONTACT_FROM_EMAIL=Portfolio Contact <onboarding@resend.dev>
# Your destination inbox
CONTACT_TO_EMAIL=you@example.com
